# Local development secrets. Copy to .env and fill in real values.
# Never commit .env. Production secrets are managed by SealedSecrets /
# External Secrets Operator.
#
#   cp .env.example .env
#
# docker-compose reads this file automatically from the monorepo root.
# Spring Boot loads it via spring.config.import in the service's
# application.yaml.

# --- bank-service: docker-compose ---
BANK_DB_USER=
BANK_DB_PASSWORD=
BANK_DB_NAME=bank_service
BANK_DB_PORT=5432

# --- bank-service: Spring Boot ---
DB_URL=jdbc:postgresql://localhost:5432/bank_service
DB_USERNAME=
DB_PASSWORD=

# --- auth (JWT, HS256) ---
# Must be at least 32 bytes (256 bits) for HS256. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# --- fraud-detection (bank-service calls it after each transfer) ---
# In Kubernetes this is set to the in-cluster service DNS by the Helm chart.
FRAUD_URL=http://localhost:8000
FRAUD_AMOUNT_THRESHOLD=10000

# --- local-only: wipe + re-migrate the DB on startup (NEVER set in k8s) ---
# Lets you iterate on the schema freely: every boot drops and rebuilds the DB
# from the migration scripts. APP_DB_CLEAN_ON_START enables the clean strategy;
# FLYWAY_CLEAN_DISABLED=false is required for Flyway to allow clean().
APP_DB_CLEAN_ON_START=true
FLYWAY_CLEAN_DISABLED=false
