# Local development secrets. Copy to .env and fill in real values.
# Never commit .env. Production secrets are managed by SealedSecrets /
# External Secrets Operator.
#
#   cp .env.example .env
#
# docker-compose reads this file automatically from the monorepo root.
# Spring Boot loads it via spring.config.import in each service's
# application.yaml.

# --- account-service: docker-compose ---
ACCOUNT_DB_USER=
ACCOUNT_DB_PASSWORD=
ACCOUNT_DB_NAME=account_service
ACCOUNT_DB_PORT=5432

# --- account-service: Spring Boot ---
DB_URL=jdbc:postgresql://localhost:5432/account_service
DB_USERNAME=
DB_PASSWORD=

# --- transaction-service: docker-compose ---
TRANSACTION_DB_USER=
TRANSACTION_DB_PASSWORD=
TRANSACTION_DB_NAME=transaction_service
TRANSACTION_DB_PORT=5433

# transaction-service Spring Boot reuses the generic DB_URL/DB_USERNAME/DB_PASSWORD
# names, so when running it locally override them inline so it points at its OWN
# database on 5433 (not account-service's), e.g.:
#   DB_URL=jdbc:postgresql://localhost:5433/transaction_service \
#   DB_USERNAME=$TRANSACTION_DB_USER DB_PASSWORD=$TRANSACTION_DB_PASSWORD \
#   SERVER_PORT=8082 ACCOUNT_SERVICE_URL=http://localhost:8080 ./mvnw spring-boot:run
