# Local development secrets. Copy to .env and fill in real values.
# Never commit .env. Production secrets are managed by SealedSecrets /
# External Secrets Operator.
#
#   cp .env.example .env
#
# docker-compose reads this file automatically from the monorepo root.
# Spring Boot loads it via spring.config.import in each service's
# application.yaml.

# --- account-service: docker-compose ---
ACCOUNT_DB_USER=
ACCOUNT_DB_PASSWORD=
ACCOUNT_DB_NAME=account_service
ACCOUNT_DB_PORT=5432

# --- account-service: Spring Boot ---
DB_URL=jdbc:postgresql://localhost:5432/account_service
DB_USERNAME=
DB_PASSWORD=
